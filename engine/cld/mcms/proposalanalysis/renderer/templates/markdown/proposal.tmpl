{{- define "proposal" -}}

{{- /* Title: show domain and environment when provided */ -}}
{{- if or .Request.Domain .Request.EnvironmentName -}}
## Proposal — {{ .Request.Domain }}{{ if .Request.EnvironmentName }} ({{ .Request.EnvironmentName }}){{ end }}

{{ end -}}

{{- $severity := annotation .Proposal.Annotations "cld.severity" -}}
{{- $proposalDelay := annotation .Proposal.Annotations "proposal_timelock_delay" -}}
{{- $minDelay := annotation .Proposal.Annotations "timelock_min_delay" -}}
{{- $delayCheck := annotation .Proposal.Annotations "timelock_delay_validation" -}}

{{- if or $proposalDelay $minDelay $delayCheck }}
**Timelock delay:** {{ if $proposalDelay }}{{ $proposalDelay }}{{ else }}unknown{{ end }}
{{- if $minDelay }}

**On-chain minDelay:** {{ $minDelay }}
{{- end }}
{{- if $delayCheck }}

**Delay check:** {{ $delayCheck }}{{ if $severity }} {{ severitySymbol $severity }}{{ end }}
{{- end }}

{{ end -}}

{{- /* Proposal-level annotations */ -}}
{{ template "annotations" .Proposal.Annotations }}

{{- /* Batch operations: one collapsible <details> per batch */ -}}
{{- $batches := .Proposal.BatchOperations -}}
{{- if $batches -}}
{{- range $i, $batch := $batches }}
<details>
<summary><h3>Batch {{ add $i 1 }} — {{ resolveChainSelector .ChainSelector }} (<code>{{ .ChainSelector }}</code>)</h3></summary>

{{ template "batchOperation" $batch }}
</details>
{{ end -}}
{{- else -}}
_No batch operations._
{{ end -}}

{{- end -}}
